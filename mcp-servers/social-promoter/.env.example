# Optional defaults for local development, CI, or deployment hosts that inject
# environment variables into the Social Promoter MCP server process.
#
# The server does not load .env files automatically. Copy values from here into
# your MCP config, deployment environment, or shell session as needed.
# Do not commit real credentials or paste them into chat.

# Optional blog defaults. Tool arguments override these values.
SOCIAL_PROMOTER_POSTS_DIR=
SOCIAL_PROMOTER_SITE_URL=
SOCIAL_PROMOTER_VOICE_FILE=

# Optional X API credentials for CI/deployment live publishing.
# Live posting needs all four. If any are missing, publish_post falls back to a dry run.
# For normal personal use, prefer `npx social-promoter-mcp login` so credentials
# are stored locally at ~/.social-promoter/credentials.json instead of in a repo.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=